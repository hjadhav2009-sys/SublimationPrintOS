{
  "name": "sublimation-print-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Phase 0 foundation scaffold for the local-first SublimationPrintOS desktop app.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "phase0:preflight": "node scripts/phase0-preflight.mjs",
    "phase0:check": "npm run phase0:preflight && npm run typecheck && npm run build",
    "phase0:package": "npm run phase0:check && npm run tauri:build",
    "phase0:inspect": "node scripts/inspect-build-artifacts.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
